# ── .env.test ─────────────────────────────────────────────────────────────────
# Used exclusively by pytest. A real MongoDB container is spun up via
# testcontainers, so these values must be valid — they are used to connect.
# The fields must also be well-formed because Pydantic Settings validates
# them at import time.

# MongoDB — used to connect to the testcontainers MongoDB instance
MONGODB_APP_USER=app_user
MONGODB_APP_PASSWORD=test-password
MONGODB_DB=test_db
MONGODB_HOST=localhost

# Agent executor
MAX_EXECUTION_STEPS=10

# Tenant API keys used in conftest.py (ALPHA / BETA / BAD)
# Format: JSON object of  { "<api-key>": "<tenant_id>" }
TENANT_API_KEYS='{"sk-tenant-alpha-000": "tenant_alpha", "sk-tenant-beta-000": "tenant_beta"}'

# Disable Redis/ARQ pool creation during tests — FakeArqPool is injected by fixture
TESTING=true

# Disable rate limiting during normal tests — rl_client fixture re-enables with a low limit
RATE_LIMIT_ENABLED=false
# Low limit so rate limit tests can exhaust it with 4 requests instead of 60
RATE_LIMIT_RUN_ENDPOINT=3/minute
# Low limit for health endpoint rate limit tests (exhausted with 3 requests)
RATE_LIMIT_HEALTH_ENDPOINT=2/minute
# Low limit for auth failure tests (exhausted with 3 bad attempts)
RATE_LIMIT_AUTH_FAILURES=3/minute