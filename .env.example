# Copy this file to .env and fill in values before running docker compose.

# ==========================================
# Database Initialization (Docker Root)
# ==========================================
# Used ONLY by docker-compose to initialize MongoDB.
# FastAPI does NOT use these credentials.
MONGODB_USER=root_admin
MONGODB_PASSWORD=CHANGE_ME_strong_random_password

# ==========================================
# Database Application User (Least Privilege)
# ==========================================
# Used by the FastAPI app to connect. Created automatically by mongo-init.js.
MONGODB_APP_USER=app_user
MONGODB_APP_PASSWORD=secure_app_password
MONGODB_DB=mini_agent_platform
# Use 'localhost:27017' if running the app locally outside of Docker
MONGODB_HOST=mongo:27017

# ==========================================
# Application Settings
# ==========================================
# Safeguard to prevent infinite LLM execution loops
MAX_EXECUTION_STEPS=10

# Multi-Tenant Authentication (JSON string mapping API keys to tenant IDs)
# In production, this would be handled by a dedicated secrets manager or auth service.
TENANT_API_KEYS='{"your-api-key-1": "tenant_a", "your-api-key-2": "tenant_b", "your-api-key-3": "tenant_c"}'

# ==========================================
# Redis / Async Queue
# ==========================================
# Use 'redis://localhost:6379' if running outside Docker
REDIS_URL=redis://redis:6379

# ==========================================
# CORS
# ==========================================
# JSON array or comma-separated list of allowed origins.
# WARNING: ["*"] allows all origins — safe for local dev only.
# In production, replace with your actual frontend origin(s):
#   CORS_ALLOWED_ORIGINS=["https://app.example.com","https://admin.example.com"]
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RUN_ENDPOINT=60/minute
RATE_LIMIT_AUTH_FAILURES=10/minute
RATE_LIMIT_HEALTH_ENDPOINT=10/minute

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=INFO
LOG_JSON=true

# ==========================================
# OpenTelemetry
# ==========================================
OTEL_ENABLED=true
# e.g. http://otel-collector:4318; leave empty for console output
OTEL_EXPORTER_OTLP_ENDPOINT=
# Defaults to APP_NAME if empty
OTEL_SERVICE_NAME=